<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}E-Voting Lab{% endblock %}</title>

    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            margin: 0;
            background: #f4f6f9;
        }

        header {
            background: #1f2937;
            color: white;
            padding: 16px 24px;
        }

        nav a {
            color: #93c5fd;
            margin-right: 15px;
            text-decoration: none;
            font-weight: 500;
        }

        nav a:hover {
            text-decoration: underline;
        }

        .container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
        }

        h1, h2, h3 {
            margin-top: 0;
        }

        .card {
            background: white;
            border-radius: 10px;
            padding: 16px;
            margin-bottom: 16px;
            box-shadow: 0 3px 8px rgba(0,0,0,0.05);
        }

        .grid {
            display: grid;
            gap: 16px;
        }

        .grid-2 {
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        }

        .btn {
            background: #2563eb;
            border: none;
            color: white;
            padding: 8px 14px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 500;
        }

        .btn:hover {
            background: #1e40af;
        }

        .btn-secondary {
            background: #6b7280;
        }

        .btn-danger {
            background: #dc2626;
        }

        .tag {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
        }

        .tag-success { background:#d1fae5; color:#065f46; }
        .tag-danger { background:#fee2e2; color:#7f1d1d; }
        .tag-warning { background:#fef3c7; color:#92400e; }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 8px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
        }

        .log-box {
            background: #111827;
            color: #e5e7eb;
            padding: 12px;
            border-radius: 8px;
            font-family: monospace;
            font-size: 13px;
            max-height: 250px;
            overflow-y: auto;
        }
        .form-row { display:flex; gap:12px; align-items:center; flex-wrap:wrap; }

        .pill-group { display:inline-flex; border:1px solid #e5e7eb; border-radius:10px; overflow:hidden; background:#fff; }
        .pill-group input { position:absolute; opacity:0; pointer-events:none; }
        .pill { padding:8px 12px; cursor:pointer; font-weight:600; font-size:14px; user-select:none; }
        .pill + .pill { border-left:1px solid #e5e7eb; }
        .pill small { font-weight:500; opacity:.75; margin-left:6px; }
        .pill-group input:checked + .pill { background:#2563eb; color:#fff; }

        .checkbox {
            display:inline-flex; align-items:center; gap:8px;
            padding:6px 10px; border:1px solid #e5e7eb; border-radius:10px; background:#fff;
            font-size:14px;
        }
        .checkbox input { width:16px; height:16px; }

        .btn { display:inline-flex; align-items:center; gap:8px; }
        .btn:active { transform: translateY(1px); }
        pre {
            background: #f9fafb;
            padding: 10px;
            border-radius: 8px;
            font-size: 13px;
            overflow-x: auto;      /* горизонтальний скрол */
            white-space: pre-wrap; /* перенос рядків */
            word-break: break-all; /* ламати довгі числа */
        }
    </style>
</head>

<body>
<header>
    <h2>E-Voting Protocol Lab</h2>
    <nav>
        <a href="{{ path('lab4_setup') }}">Setup</a>
        <a href="{{ path('lab4_dashboard') }}">Dashboard</a>
        <a href="{{ path('lab4_publish') }}">Publish</a>
        <a href="{{ path('lab4_results') }}">Results</a>
    </nav>
</header>

<div class="container">
    {% block body %}{% endblock %}
</div>
</body>
</html>
